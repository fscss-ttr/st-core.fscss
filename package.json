{
  "name": "st-core",
  "version": "1.1.0",
  "description": "Lightweight FSCSS - based UI library for statistical dashboard and components",
  "extension": "fscss",
  "fscss_version": "^1.1.24",
  "blocked_methods": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/fscss-ttr/st-core.fscss"
  },
  "bugs": {
    "url": "https://github.com/fscss-ttr/st-core.fscss/issues"
  },
  "file": {
    "usage": {
      "directive": "st-*",
      "helpers": [
        "st-root",
        "st-container",
        "st-chart-fill",
        "st-chart-line",
        "st-chart-dot",
        "st-chart-dots", 
        "st-chart-points",
        "st-chart-line-width",
        "st-stat-card"
      ]
    },
    "modules": [
      "./st-core.fscss"
    ],
    "remote": "./st-core.fscss"
  },
  "author": {
    "name": "fscss-ttr"
  },
  "keywords": [
    "fscss",
    "css",
    "lightweight",
    "fscss-based",
    "dashboard-ui",
    "utility",
    "statistics"
  ],
  "license": "MIT"
}
